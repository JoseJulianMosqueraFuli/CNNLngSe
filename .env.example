# Ejemplo de variables de entorno para sign-classifier.
# Copia este archivo a .env y ajusta los valores según tu entorno.
# NUNCA subas .env al repositorio; ya está protegido por .gitignore.

# =============================================================================
# Configuración de imágenes
# =============================================================================
SIGN_CLASSIFIER_IMAGE_WIDTH=150
SIGN_CLASSIFIER_IMAGE_HEIGHT=150
SIGN_CLASSIFIER_IMAGE_CHANNELS=3

# =============================================================================
# Configuración de entrenamiento
# =============================================================================
SIGN_CLASSIFIER_EPOCHS=20
SIGN_CLASSIFIER_BATCH_SIZE=32
SIGN_CLASSIFIER_LEARNING_RATE=0.0004

# Activar transfer learning (true/false)
SIGN_CLASSIFIER_USE_TRANSFER_LEARNING=false
SIGN_CLASSIFIER_TRANSFER_LEARNING_BACKBONE=mobilenet_v3

# =============================================================================
# Rutas del proyecto
# =============================================================================
SIGN_CLASSIFIER_TRAINING_DATA_PATH=./data/entrenamiento
SIGN_CLASSIFIER_VALIDATION_DATA_PATH=./data/validacion
SIGN_CLASSIFIER_MODEL_PATH=./modelo/modelo.keras
SIGN_CLASSIFIER_LOG_DIR=./logs
SIGN_CLASSIFIER_METRICS_DIR=./metrics

# =============================================================================
# Clases a clasificar (separadas por comas)
# =============================================================================
SIGN_CLASSIFIER_CLASSES=a,b,c
